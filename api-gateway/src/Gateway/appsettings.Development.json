{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Information"
    }
  },
  "Jwt": {
    "Secret": "fintech-auth-local-dev-secret-key-32chars!",
    "Issuer": "fintech-auth-service",
    "Audience": "fintech-platform"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-public": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Metadata": {
          "Description": "Auth routes — no requieren JWT (login/register)"
        }
      },
      "transactions-authenticated": {
        "ClusterId": "transactions-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/transactions/{**catch-all}"
        },
        "Metadata": {
          "Description": "Transactions routes — requieren JWT válido"
        }
      },
      "accounts-authenticated": {
        "ClusterId": "accounts-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/v1/accounts/{**catch-all}"
        },
        "Metadata": {
          "Description": "Accounts/queries routes — requieren JWT válido"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-primary": {
            "Address": "http://localhost:5010"
          }
        }
      },
      "transactions-cluster": {
        "Destinations": {
          "transactions-primary": {
            "Address": "http://localhost:5000"
          }
        }
      },
      "accounts-cluster": {
        "Destinations": {
          "accounts-primary": {
            "Address": "http://localhost:5020"
          }
        }
      }
    }
  }
}
