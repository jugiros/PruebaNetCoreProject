{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Auth Service",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build:auth-service",
            "program": "${workspaceFolder}/auth-service/src/Presentation/API/bin/Debug/net9.0/AuthService.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/auth-service/src/Presentation/API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5011;http://localhost:5010"
            },
            "console": "internalConsole",
            "sourceFileMap": {
                "/Views": "${workspaceFolder}"
            }
        },
        {
            "name": "Launch Auth Service (watch)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "watch:auth-service",
            "program": "${workspaceFolder}/auth-service/src/Presentation/API/bin/Debug/net9.0/AuthService.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/auth-service/src/Presentation/API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5011;http://localhost:5010",
                "DOTNET_USE_POLLING_FILE_WATCHER": "1"
            },
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Launch Core Transactions Service",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build:core-transactions-service",
            "program": "${workspaceFolder}/core-transactions-service/src/Presentation/API/bin/Debug/net9.0/PruebaNetCoreProject.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/core-transactions-service/src/Presentation/API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
            },
            "console": "internalConsole",
            "sourceFileMap": {
                "/Views": "${workspaceFolder}"
            }
        },
        {
            "name": "Launch Core Transactions Service (watch)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "watch:core-transactions-service",
            "program": "${workspaceFolder}/core-transactions-service/src/Presentation/API/bin/Debug/net9.0/PruebaNetCoreProject.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/core-transactions-service/src/Presentation/API",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000",
                "DOTNET_USE_POLLING_FILE_WATCHER": "1"
            },
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        },
        {
            "name": "Launch API Gateway",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build:api-gateway",
            "program": "${workspaceFolder}/api-gateway/src/Gateway/bin/Debug/net9.0/ApiGateway.dll",
            "args": [],
            "cwd": "${workspaceFolder}/api-gateway/src/Gateway",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5443;http://localhost:5100"
            },
            "console": "internalConsole",
            "sourceFileMap": {
                "/Views": "${workspaceFolder}"
            }
        },
        {
            "name": "Attach to Process",
            "type": "coreclr",
            "request": "attach"
        }
    ],
    "compounds": [
        {
            "name": "Launch All Services",
            "configurations": [
                "Launch Auth Service",
                "Launch Core Transactions Service",
                "Launch API Gateway"
            ],
            "stopAll": true
        }
    ]
}
