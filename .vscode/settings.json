{
    "dotnet.defaultSolution": "auth-service/AuthService.sln",
    "omnisharp.enableRoslynAnalyzers": true,
    "omnisharp.enableEditorConfigSupport": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    "files.exclude": {
        "**/bin": true,
        "**/obj": true,
        "**/.vs": true,
        "**/TestResults": true
    },
    "files.watcherExclude": {
        "**/bin/**": true,
        "**/obj/**": true,
        "**/TestResults/**": true
    },
    "files.associations": {
        "*.csproj": "xml",
        "*.props": "xml",
        "*.targets": "xml",
        "*.sln": "ini",
        "Dockerfile*": "dockerfile"
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.csproj": "*.user",
        "appsettings.json": "appsettings.*.json",
        "Program.cs": "Startup.cs, GlobalExceptionHandler.cs"
    },
    "dotnet-test-explorer.testProjectPath": "**/*.Tests.csproj",
    "dotnet-test-explorer.autoWatch": false,
    "rest-client.environmentVariables": {
        "$shared": {
            "authBaseUrl": "http://localhost:5010",
            "transactionsBaseUrl": "http://localhost:5000"
        },
        "local": {
            "authToken": ""
        }
    },
    "docker.defaultRegistryPath": "ghcr.io/tandicorp",
    "terminal.integrated.env.windows": {
        "ASPNETCORE_ENVIRONMENT": "Development"
    },
    "csharp.debug.console": "internalConsole",
    "dotnet.completion.showCompletionItemsFromUnimportedNamespaces": true,
    "dotnet.formatting.organizeImportsOnFormat": true,
    "[csharp]": {
        "editor.defaultFormatter": "muhammad-sammy.csharp",
        "editor.formatOnSave": true
    },
    "sonarlint.rules": {
        "csharpsquid:S2068": { "level": "on" },
        "csharpsquid:S2077": { "level": "on" },
        "csharpsquid:S1186": { "level": "on" }
    }
}