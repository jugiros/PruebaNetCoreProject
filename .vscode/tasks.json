{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build:auth-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/auth-service/src/Presentation/API/API.csproj",
                "--configuration",
                "Debug",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "build:core-transactions-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/core-transactions-service/src/Presentation/API/API.csproj",
                "--configuration",
                "Debug",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "build:all",
            "dependsOn": [
                "build:auth-service",
                "build:core-transactions-service"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish:auth-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/auth-service/src/Presentation/API/API.csproj",
                "--configuration",
                "Release",
                "--output",
                "${workspaceFolder}/auth-service/publish"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "publish:core-transactions-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/core-transactions-service/src/Presentation/API/API.csproj",
                "--configuration",
                "Release",
                "--output",
                "${workspaceFolder}/core-transactions-service/publish"
            ],
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "watch:auth-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/auth-service/src/Presentation/API/API.csproj"
            ],
            "problemMatcher": "$msCompile",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "watch:core-transactions-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/core-transactions-service/src/Presentation/API/API.csproj"
            ],
            "problemMatcher": "$msCompile",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "test:auth-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/auth-service/AuthService.sln",
                "--configuration",
                "Debug",
                "--logger",
                "trx",
                "--results-directory",
                "${workspaceFolder}/auth-service/TestResults"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "test:core-transactions-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/core-transactions-service/PruebaNetCoreProject.sln",
                "--configuration",
                "Debug",
                "--logger",
                "trx",
                "--results-directory",
                "${workspaceFolder}/core-transactions-service/TestResults"
            ],
            "problemMatcher": "$msCompile",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "test:all",
            "dependsOn": [
                "test:auth-service",
                "test:core-transactions-service"
            ],
            "dependsOrder": "parallel",
            "group": "test",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "ef:auth:migrations:add",
            "command": "dotnet",
            "type": "process",
            "args": [
                "ef",
                "migrations",
                "add",
                "${input:migrationName}",
                "--project",
                "${workspaceFolder}/auth-service/src/Infrastructure/Persistence",
                "--startup-project",
                "${workspaceFolder}/auth-service/src/Presentation/API"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "ef:auth:database:update",
            "command": "dotnet",
            "type": "process",
            "args": [
                "ef",
                "database",
                "update",
                "--project",
                "${workspaceFolder}/auth-service/src/Infrastructure/Persistence",
                "--startup-project",
                "${workspaceFolder}/auth-service/src/Presentation/API"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "ef:auth:database:drop",
            "command": "dotnet",
            "type": "process",
            "args": [
                "ef",
                "database",
                "drop",
                "--force",
                "--project",
                "${workspaceFolder}/auth-service/src/Infrastructure/Persistence",
                "--startup-project",
                "${workspaceFolder}/auth-service/src/Presentation/API"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "docker:infra:up",
            "command": "docker",
            "type": "process",
            "args": [
                "compose",
                "-f",
                "${workspaceFolder}/docker/docker-compose.infra.yml",
                "up",
                "-d"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "docker:infra:down",
            "command": "docker",
            "type": "process",
            "args": [
                "compose",
                "-f",
                "${workspaceFolder}/docker/docker-compose.infra.yml",
                "down"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "docker:build:auth-service",
            "command": "docker",
            "type": "process",
            "args": [
                "build",
                "-t",
                "auth-service:dev",
                "-f",
                "${workspaceFolder}/auth-service/Dockerfile",
                "${workspaceFolder}/auth-service"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "format:auth-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "format",
                "${workspaceFolder}/auth-service/AuthService.sln",
                "--severity",
                "warn",
                "--verbosity",
                "diagnostic"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "format:verify-auth-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "format",
                "${workspaceFolder}/auth-service/AuthService.sln",
                "--verify-no-changes",
                "--severity",
                "warn"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "restore:all",
            "command": "dotnet",
            "type": "process",
            "args": [
                "restore",
                "${workspaceFolder}/auth-service/AuthService.sln"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "migrationName",
            "description": "Nombre de la migración EF Core",
            "default": "InitialCreate",
            "type": "promptString"
        }
    ]
}
